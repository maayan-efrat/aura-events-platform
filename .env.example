# Copy to .env and fill in real values. .env is gitignored — never commit real secrets.

# Postgres (shared instance, one database per service — see docs/architecture/01-system-architecture.md)
POSTGRES_USER=auraevents
POSTGRES_PASSWORD=nghinvnn,

# JWT (RS256) — Identity.Api signs, Events.Api validates via /keys/jwt-public.pem
JWT_ISSUER=https://identity.auraevents.local
JWT_AUDIENCE=auraevents-clients

# CORS — the Next.js frontend origin allowed to call Identity.Api / Events.Api
FRONTEND_ORIGIN=http://localhost:3000

# Umbraco unattended install (creates the initial backoffice admin on first boot)
UMBRACO_ADMIN_NAME=AuraEvents Admin
UMBRACO_ADMIN_EMAIL=admin@auraevents.local
UMBRACO_ADMIN_PASSWORD=change-me-min-10-chars

# OpenAI — used by Events.Api for recommendations + AI-generated event descriptions.
# Get a key at https://platform.openai.com/api-keys. Never commit a real key or paste it in chat.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Umbraco Management API service account — used by Events.Api to create/publish eventPage
# content when an organizer submits the "new event" form. This is a one-time manual setup step
# (see README "One-time Umbraco setup"): create an API User via the Umbraco backoffice
# (Settings -> Users -> Create -> API User), grant it Create+Publish permissions on the content
# root, generate its client credentials, and paste them here.
UMBRACO_MANAGEMENT_CLIENT_ID=umbraco-back-office-events-api
UMBRACO_MANAGEMENT_CLIENT_SECRET=change-me-generated-by-umbraco

# Shared secrets for internal service-to-service calls (never exposed to the frontend). Generate
# with e.g. `openssl rand -hex 32`.
CATEGORY_SYNC_KEY=change-me-generated-random-hex
USERS_SYNC_KEY=change-me-generated-random-hex
