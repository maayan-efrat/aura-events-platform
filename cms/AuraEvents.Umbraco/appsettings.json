{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "umbracoDbDSN": "Host=localhost;Port=5432;Database=auraevents_cms;Username=auraevents;Password=changeme-in-env;Include Error Detail=true",
    "umbracoDbDSN_ProviderName": "Npgsql2"
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "Id": "bef8666a-eab8-4012-b2ae-ef034e599eb8",
        "UseHttps": false
      },
      "Content": {
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        }
      },
      "Unattended": {
        "InstallUnattended": true,
        "UpgradeUnattended": true
      },
      "DeliveryApi": {
        "Enabled": true,
        "PublicAccess": true
      },
      "Security": {
        "AllowConcurrentLogins": false
      }
    }
  }
}
