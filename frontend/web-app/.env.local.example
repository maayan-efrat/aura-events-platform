# Copy to .env.local for local dev (gitignored by default in Next.js projects).
# Server-side only — never prefixed with NEXT_PUBLIC_, since the browser must never
# talk to these origins directly (that's the whole point of the BFF pattern).
IDENTITY_API_URL=http://localhost:5001
EVENTS_API_URL=http://localhost:5002
UMBRACO_URL=http://localhost:5003
