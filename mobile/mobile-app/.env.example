# Copy to .env for local dev. Expo inlines EXPO_PUBLIC_* vars at build time.
#
# src/lib/config.ts picks the right default per platform automatically (10.0.2.2 for the Android
# emulator, localhost for web/iOS simulator) — leave these commented out unless you're on a
# physical device, where you need your machine's LAN IP (e.g. 192.168.1.23) instead.
# EXPO_PUBLIC_IDENTITY_API_URL=http://192.168.1.23:5001
# EXPO_PUBLIC_EVENTS_API_URL=http://192.168.1.23:5002
