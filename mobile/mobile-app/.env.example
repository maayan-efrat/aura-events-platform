# Copy to .env for local dev. Expo inlines EXPO_PUBLIC_* vars at build time.
#
# Android emulator: 10.0.2.2 maps to your host machine's localhost.
# iOS simulator: localhost works directly.
# Physical device: use your machine's LAN IP (e.g. 192.168.1.23), not localhost.
EXPO_PUBLIC_IDENTITY_API_URL=http://10.0.2.2:5001
EXPO_PUBLIC_EVENTS_API_URL=http://10.0.2.2:5002
